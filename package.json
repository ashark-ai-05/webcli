{
  "name": "webcli",
  "version": "0.1.0",
  "description": "Secure, agent-driven web data extraction",
  "type": "module",
  "bin": {
    "webcli": "dist/main.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r adapters dist/",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "undici": "^7.24.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
